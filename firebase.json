{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "web_public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/s/**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/s/**",
        "headers": [
          {"key": "Cache-Control", "value": "public, max-age=60"}
        ]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "ios": {
        "default": {
          "projectId": "mannnaka",
          "appId": "1:994245428850:ios:753f7b122d9f9f507e24eb",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "mannnaka",
          "configurations": {
            "ios": "1:994245428850:ios:753f7b122d9f9f507e24eb"
          }
        }
      }
    }
  }
}
