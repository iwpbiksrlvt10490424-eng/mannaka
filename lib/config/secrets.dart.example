/// 🔐 シークレット設定テンプレート
/// このファイルを secrets.dart としてコピーし、実際のキーを設定してください。
/// secrets.dart は .gitignore に追加されており、リポジトリにはコミットされません。
class Secrets {
  /// Hotpepper グルメAPI キー
  static const String hotpepperApiKey = 'YOUR_HOTPEPPER_API_KEY';

  /// Foursquare Places API v3 キー
  static const String foursquareApiKey = 'YOUR_FOURSQUARE_API_KEY';

  /// Google Maps API キー（iOS ネイティブ側は ios/Flutter/Secrets.xcconfig を参照）
  static const String googleMapsApiKey = 'YOUR_GOOGLE_MAPS_API_KEY';

  /// Google Geocoding API キー
  static const String geocodingApiKey = 'YOUR_GEOCODING_API_KEY';
}
